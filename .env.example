# CTS v3.2 - Environment Variables for Independent Deployment
# Copy to .env.local and configure

# ========== Application ==========
NODE_ENV=production
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ========== Security ==========
JWT_SECRET=your-jwt-secret-min-32-chars-long-change-this
SESSION_SECRET=your-session-secret-min-32-chars
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# ========== Redis Database ==========
REDIS_PERSISTENCE=true
REDIS_SNAPSHOT_PATH=./data/redis-snapshot.json
# For external Redis:
# REDIS_URL=redis://:password@localhost:6379

# ========== Exchange API Keys ==========
# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# BingX
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_TESTNET=true

# Add other exchanges as needed...

# ========== System Settings ==========
# Enable/disable features
ENABLE_LIVE_TRADING=false
ENABLE_BACKTESTING=true
ENABLE_PAPER_TRADING=true

# Logging
LOG_LEVEL=info
# DEBUG=*
